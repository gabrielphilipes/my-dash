{
  // Extende a configuração padrão do Nuxt
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "allowJs": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "useDefineForClassFields": true
  },
  "vueCompilerOptions": {
    "target": 3.3
  }
}
