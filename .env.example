# Senha para encriptar as sessões (mínimo 32 caracteres)
NUXT_SESSION_PASSWORD=sua-senha-super-secreta-com-32-caracteres

# GitHub OAuth
NUXT_OAUTH_GITHUB_CLIENT_ID=seu-client-id
NUXT_OAUTH_GITHUB_CLIENT_SECRET=seu-client-secret

# Google OAuth
NUXT_OAUTH_GOOGLE_CLIENT_ID=seu-client-id
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=seu-client-secret

# Facebook OAuth
NUXT_OAUTH_FACEBOOK_CLIENT_ID=seu-client-id
NUXT_OAUTH_FACEBOOK_CLIENT_SECRET=seu-client-secret 